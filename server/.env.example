# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
APP_VERSION=0.1.0

# ── PostgreSQL (local / Railway / Supabase) ──────────
# Use DATABASE_URL OR individual fields below
DATABASE_URL=postgresql://leafyland:leafyland@localhost:5432/leafyland

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=leafyland
DATABASE_PASSWORD=leafyland
DATABASE_NAME=leafyland
DATABASE_SSL=false

# Set false to start API without waiting for DB (dev only)
DATABASE_REQUIRED=true
