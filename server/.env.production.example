# ── App (production) ─────────────────────────────────
NODE_ENV=production
PORT=4000
API_PREFIX=api
APP_VERSION=0.1.0

# Railway / Supabase / managed Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=true
DATABASE_REQUIRED=true

# Optional: set by CI/CD (Railway, GitHub Actions)
# BUILD_SHA=
